OPENAI_API_KEY=your_key_here
USETRANSCRIBE_API_KEY=your_key_here
YOUTUBE_API_KEY=your_key_here

# Optional: use an OpenAI-compatible provider instead of api.openai.com.
# Example — GitHub Models (free GPT-4o, token from github.com/settings/personal-access-tokens):
# OPENAI_API_KEY=github_pat_...
# OPENAI_BASE_URL=https://models.github.ai/inference
# OPENAI_MODEL=openai/gpt-4o
# OPENAI_IMAGE_DETAIL=low
