OPENAI_API_KEY=your_key_here

# usetranscribe.io currently requires no API key (rate-limited per IP:
# 50 transcriptions/day). Leave blank unless the service starts requiring one.
USETRANSCRIBE_API_KEY=

# Not used by the pipeline — video validation uses YouTube's public oEmbed
# endpoint and yt-dlp, neither of which needs a key. Kept for future use.
YOUTUBE_API_KEY=

# Optional: use an OpenAI-compatible provider instead of api.openai.com.
# Example — GitHub Models (free GPT-4o, token from github.com/settings/personal-access-tokens):
# OPENAI_API_KEY=github_pat_...
# OPENAI_BASE_URL=https://models.github.ai/inference
# OPENAI_MODEL=openai/gpt-4o
# (GitHub Models only: also set OPENAI_IMAGE_DETAIL=low — see README)
